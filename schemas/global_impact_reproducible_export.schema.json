{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.org/schemas/global-impact-catalyst/1.8.0/global_impact_reproducible_export.schema.json",
  "title": "Global Impact Catalyst Reproducible Export Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle_type","bundle_version","workspace_id","initiative_id","report_id","publication_snapshot_id","artifacts","reproducibility","boundary"],
  "properties": {
    "bundle_type": {"const":"global_impact_reproducible_export"},
    "bundle_version": {"const":"1.8.0"},
    "workspace_id": {"type":"string","minLength":1},
    "initiative_id": {"type":["string","null"]},
    "report_id": {"type":["string","null"]},
    "publication_snapshot_id": {"type":["string","null"]},
    "artifacts": {"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["path","media_type","byte_size","sha256"],"properties":{"path":{"type":"string","minLength":1},"media_type":{"type":"string","minLength":1},"byte_size":{"type":"integer","minimum":0},"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"}}}},
    "reproducibility": {"type":"object","required":["deterministic_zip_timestamps","hash_algorithm"],"properties":{"deterministic_zip_timestamps":{"const":true},"hash_algorithm":{"const":"sha256"}},"additionalProperties":false},
    "boundary": {"type":"string","minLength":1}
  },
  "x-global-impact-catalyst-version": "1.8.0"
}
