{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.org/schemas/global-impact-catalyst/1.6.0/global_impact_review_workflow.schema.json",
  "title": "Global Impact Catalyst Review Workflow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_type",
    "workflow_version",
    "workspace_id",
    "generated_at",
    "roles",
    "review_assignments",
    "review_comments",
    "quality_assessments",
    "approval_decisions",
    "revisions",
    "corrections",
    "publications",
    "publication_events",
    "integrity",
    "boundary"
  ],
  "properties": {
    "workflow_type": {
      "const": "global_impact_review_workflow"
    },
    "workflow_version": {
      "const": "1.6.0"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "roles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/role"
      }
    },
    "review_assignments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assignment"
      }
    },
    "review_comments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/comment"
      }
    },
    "quality_assessments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assessment"
      }
    },
    "approval_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "revisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/revision"
      }
    },
    "corrections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/correction"
      }
    },
    "publications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/publication"
      }
    },
    "publication_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/publicationEvent"
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid",
        "role_count",
        "assignment_count",
        "comment_count",
        "open_comment_count",
        "quality_assessment_count",
        "approval_decision_count",
        "revision_count",
        "correction_count",
        "open_correction_count",
        "publication_count",
        "broken_decision_ids",
        "published_without_gate_ids"
      ],
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "role_count": {
          "type": "integer",
          "minimum": 0
        },
        "assignment_count": {
          "type": "integer",
          "minimum": 0
        },
        "comment_count": {
          "type": "integer",
          "minimum": 0
        },
        "open_comment_count": {
          "type": "integer",
          "minimum": 0
        },
        "quality_assessment_count": {
          "type": "integer",
          "minimum": 0
        },
        "approval_decision_count": {
          "type": "integer",
          "minimum": 0
        },
        "revision_count": {
          "type": "integer",
          "minimum": 0
        },
        "correction_count": {
          "type": "integer",
          "minimum": 0
        },
        "open_correction_count": {
          "type": "integer",
          "minimum": 0
        },
        "publication_count": {
          "type": "integer",
          "minimum": 0
        },
        "broken_decision_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "published_without_gate_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "boundary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "metadata": {
      "type": "object"
    },
    "subjectType": {
      "enum": [
        "contract",
        "initiative",
        "evidence_repository",
        "indicator_registry",
        "measurement_repository",
        "impact_result",
        "observation",
        "publication"
      ]
    },
    "role": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "role_id",
        "workspace_id",
        "name",
        "permissions",
        "revision",
        "metadata"
      ],
      "properties": {
        "role_id": {
          "type": "string",
          "minLength": 1
        },
        "workspace_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "assignment_id",
        "workspace_id",
        "initiative_id",
        "subject_type",
        "subject_id",
        "reviewer_id",
        "role_id",
        "status",
        "priority",
        "revision",
        "metadata"
      ],
      "properties": {
        "subject_type": {
          "$ref": "#/$defs/subjectType"
        },
        "status": {
          "enum": [
            "pending",
            "in_review",
            "changes_requested",
            "approved",
            "rejected",
            "cancelled"
          ]
        },
        "priority": {
          "enum": [
            "low",
            "normal",
            "high",
            "urgent"
          ]
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "comment": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "comment_id",
        "assignment_id",
        "workspace_id",
        "initiative_id",
        "subject_type",
        "subject_id",
        "author_id",
        "visibility",
        "body",
        "resolution_status",
        "revision",
        "metadata"
      ],
      "properties": {
        "subject_type": {
          "$ref": "#/$defs/subjectType"
        },
        "visibility": {
          "enum": [
            "workspace",
            "reviewers",
            "private"
          ]
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "resolution_status": {
          "enum": [
            "open",
            "resolved",
            "wont_fix"
          ]
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "assessment_id",
        "workspace_id",
        "initiative_id",
        "subject_type",
        "subject_id",
        "rubric_id",
        "rubric_version",
        "assessor_id",
        "status",
        "score",
        "maximum_score",
        "grade",
        "dimensions",
        "findings",
        "revision",
        "metadata"
      ],
      "properties": {
        "subject_type": {
          "$ref": "#/$defs/subjectType"
        },
        "status": {
          "enum": [
            "draft",
            "submitted",
            "superseded"
          ]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "maximum_score": {
          "const": 100.0
        },
        "grade": {
          "enum": [
            "excellent",
            "strong",
            "adequate",
            "weak"
          ]
        },
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "key",
              "score",
              "maximum_score",
              "weight",
              "finding"
            ],
            "additionalProperties": false,
            "properties": {
              "key": {
                "type": "string",
                "minLength": 1
              },
              "score": {
                "type": "number",
                "minimum": 0
              },
              "maximum_score": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "weight": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "finding": {
                "type": "string"
              }
            }
          }
        },
        "findings": {
          "type": "array"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "decision_id",
        "assignment_id",
        "workspace_id",
        "initiative_id",
        "subject_type",
        "subject_id",
        "reviewer_id",
        "decision",
        "rationale",
        "conditions",
        "decided_at",
        "revision",
        "metadata"
      ],
      "properties": {
        "subject_type": {
          "$ref": "#/$defs/subjectType"
        },
        "decision": {
          "enum": [
            "approve",
            "request_changes",
            "reject",
            "abstain"
          ]
        },
        "conditions": {
          "type": "array"
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "revision": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "workflow_revision_id",
        "workspace_id",
        "initiative_id",
        "subject_type",
        "subject_id",
        "revision_number",
        "change_type",
        "actor_id",
        "summary",
        "content_hash",
        "snapshot",
        "created_at",
        "metadata"
      ],
      "properties": {
        "subject_type": {
          "$ref": "#/$defs/subjectType"
        },
        "revision_number": {
          "type": "integer",
          "minimum": 1
        },
        "change_type": {
          "enum": [
            "create",
            "edit",
            "review_response",
            "correction",
            "publish",
            "withdraw",
            "restore"
          ]
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "snapshot": {
          "type": "object"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "correction": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "correction_id",
        "workspace_id",
        "initiative_id",
        "subject_type",
        "subject_id",
        "severity",
        "status",
        "reason",
        "proposed_changes",
        "opened_by",
        "opened_at",
        "resolution_notes",
        "revision",
        "metadata"
      ],
      "properties": {
        "subject_type": {
          "$ref": "#/$defs/subjectType"
        },
        "severity": {
          "enum": [
            "minor",
            "material",
            "critical"
          ]
        },
        "status": {
          "enum": [
            "open",
            "applied",
            "rejected",
            "cancelled"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "proposed_changes": {
          "type": "object"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "publication_id",
        "workspace_id",
        "initiative_id",
        "subject_type",
        "subject_id",
        "title",
        "publication_status",
        "content_hash",
        "revision",
        "metadata"
      ],
      "properties": {
        "subject_type": {
          "$ref": "#/$defs/subjectType"
        },
        "publication_status": {
          "enum": [
            "draft",
            "published",
            "withdrawn",
            "superseded"
          ]
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "publicationEvent": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "publication_event_id",
        "publication_id",
        "event_type",
        "actor_id",
        "reason",
        "event_at",
        "details"
      ],
      "properties": {
        "event_at": {
          "type": "string",
          "format": "date-time"
        },
        "details": {
          "type": "object"
        }
      }
    }
  },
  "x-global-impact-catalyst-version": "1.6.0"
}
