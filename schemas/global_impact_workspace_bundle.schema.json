{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.org/schemas/global-impact-catalyst/1.7.0/global_impact_workspace_bundle.schema.json",
  "title": "Global Impact Catalyst Workspace Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_type",
    "bundle_version",
    "database_schema_version",
    "exported_at",
    "workspace",
    "contracts",
    "portfolios",
    "evidence_repository",
    "indicator_registry",
    "measurement_repository",
    "review_workflow",
    "analysis_repository",
    "audit"
  ],
  "properties": {
    "bundle_type": {
      "const": "global_impact_workspace_bundle"
    },
    "bundle_version": {
      "const": "1.7.0"
    },
    "database_schema_version": {
      "type": "integer",
      "minimum": 8
    },
    "exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "workspace": {
      "type": "object",
      "required": [
        "entity_type",
        "entity_id",
        "document"
      ],
      "additionalProperties": true
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_id",
          "workspace_id",
          "initiative_id",
          "revision",
          "content_hash",
          "contract"
        ],
        "additionalProperties": true
      }
    },
    "portfolios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "portfolio_id",
          "workspace_id",
          "name",
          "initiative_ids"
        ],
        "additionalProperties": true
      }
    },
    "evidence_repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_type",
        "repository_version",
        "workspace_id",
        "sources",
        "source_versions",
        "evidence_items",
        "datasets",
        "provenance_edges",
        "claim_evidence_links"
      ],
      "properties": {
        "repository_type": {
          "const": "global_impact_evidence_repository"
        },
        "repository_version": {
          "const": "1.3.0"
        },
        "workspace_id": {
          "type": "string",
          "minLength": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "source_versions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "evidence_items": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "provenance_edges": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "claim_evidence_links": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "audit": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "indicator_registry": {
      "type": "object",
      "required": [
        "registry_type",
        "registry_version",
        "workspace_id",
        "units",
        "indicator_definitions",
        "baseline_models",
        "target_models",
        "method_definitions",
        "bindings",
        "integrity"
      ],
      "additionalProperties": true,
      "properties": {
        "registry_type": {
          "const": "global_impact_indicator_registry"
        },
        "registry_version": {
          "const": "1.4.0"
        }
      }
    },
    "measurement_repository": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "repository_type",
        "repository_version",
        "workspace_id",
        "impact_results",
        "observations",
        "beneficiary_definitions",
        "beneficiary_observations",
        "financial_records",
        "outcome_portfolios",
        "integrity"
      ],
      "properties": {
        "repository_type": {
          "const": "global_impact_measurement_repository"
        },
        "repository_version": {
          "const": "1.5.0"
        },
        "workspace_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review_workflow": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "workflow_type",
        "workflow_version",
        "workspace_id",
        "roles",
        "review_assignments",
        "review_comments",
        "quality_assessments",
        "approval_decisions",
        "revisions",
        "corrections",
        "publications",
        "publication_events",
        "integrity"
      ],
      "properties": {
        "workflow_type": {
          "const": "global_impact_review_workflow"
        },
        "workflow_version": {
          "const": "1.6.0"
        },
        "workspace_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "analysis_repository": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "repository_type",
        "repository_version",
        "workspace_id",
        "benchmarks",
        "comparison_sets",
        "scenarios",
        "uncertainty_models",
        "analysis_runs",
        "sensitivity_runs",
        "integrity"
      ],
      "properties": {
        "repository_type": {
          "const": "global_impact_analysis_repository"
        },
        "repository_version": {
          "const": "1.7.0"
        },
        "workspace_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "x-global-impact-catalyst-version": "1.7.0"
}
