{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.org/schemas/global-impact-catalyst/1.3.0/global_impact_evidence_repository.schema.json",
  "title": "Global Impact Catalyst Evidence Repository Export",
  "type": "object",
  "additionalProperties": false,
  "required": ["repository_type", "repository_version", "workspace_id", "sources", "source_versions", "evidence_items", "datasets", "provenance_edges", "claim_evidence_links"],
  "properties": {
    "repository_type": {"const": "global_impact_evidence_repository"},
    "repository_version": {"const": "1.3.0"},
    "workspace_id": {"type": "string", "minLength": 1},
    "sources": {"type": "array", "items": {"type": "object"}},
    "source_versions": {"type": "array", "items": {"type": "object"}},
    "evidence_items": {"type": "array", "items": {"type": "object"}},
    "datasets": {"type": "array", "items": {"type": "object"}},
    "provenance_edges": {"type": "array", "items": {"type": "object"}},
    "claim_evidence_links": {"type": "array", "items": {"type": "object"}}
  },
  "x-global-impact-catalyst-version": "1.3.0"
}
